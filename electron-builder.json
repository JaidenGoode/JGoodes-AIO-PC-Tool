{
  "appId": "com.jaidengoode.aio-pc-tool",
  "productName": "JGoode AIO PC Tool",
  "copyright": "Copyright © 2025 JaidenGoode",
  "electronVersion": "33.4.11",
  "npmRebuild": false,
  "asar": false,
  "extraMetadata": {
    "main": "electron/main.cjs",
    "version": "2.5.0",
    "description": "JGoode A.I.O PC Tool — All-in-one Windows optimizer with tweaks, cleaner, DNS manager, restore points and live system monitoring.",
    "author": "JaidenGoode"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "electron/icon.ico",
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "JGoode AIO PC Tool",
    "installerIcon": "electron/icon.ico",
    "uninstallerIcon": "electron/icon.ico"
  }
}
