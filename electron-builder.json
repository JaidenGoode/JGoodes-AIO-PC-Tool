{
  "appId": "com.jaidengoode.aio-pc-tool",
  "productName": "JGoode's A.I.O PC Tool",
  "copyright": "Copyright © 2025 JaidenGoode",
  "electronVersion": "33.4.11",
  "npmRebuild": false,
  "asar": true,
  "extraMetadata": {
    "name": "jgoodes-aio-pc-tool",
    "main": "electron/main.cjs",
    "version": "3.5.0",
    "description": "JGoode's A.I.O PC Tool — All-in-one Windows optimizer with 100 PowerShell tweaks, system cleaner, DNS manager, restore points and live system monitoring.",
    "author": "JaidenGoode"
  },
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    { "from": "server/profiles", "to": "profiles", "filter": ["**/*"] },
    { "from": "server/executables", "to": "executables", "filter": ["**/*"] }
  ],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "electron/icon.ico",
    "requestedExecutionLevel": "requireAdministrator",
    "artifactName": "JGoode's A.I.O PC Tool Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "JGoode's A.I.O PC Tool",
    "installerIcon": "electron/icon.ico",
    "uninstallerIcon": "electron/icon.ico"
  }
}
