<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:JGoodeAIO.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="JGoodeAIO.Views.TweaksView"
             x:DataType="vm:TweaksViewModel"
             Background="{DynamicResource AppBackground}">

  <Grid RowDefinitions="Auto,*">

    <!-- ── Header ── -->
    <StackPanel Grid.Row="0" Margin="28,24,28,12">

      <!-- Title + Apply button -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Classes="page-title" Text="System Tweaks"/>
          <TextBlock Classes="page-subtitle"
                     Text="{Binding EnabledCount, StringFormat='Toggle tweaks on or off · {0} selected · Press Apply to run them'}"/>
        </StackPanel>

        <Button Grid.Column="1" Classes="primary" Command="{Binding ApplyCommand}"
                IsEnabled="{Binding !IsBusy}" VerticalAlignment="Center"
                Padding="18,10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <mi:MaterialIcon Kind="Play" Width="16" Height="16" VerticalAlignment="Center"/>
            <TextBlock Text="Apply" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- Quick-select row -->
      <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,10,0,0">
        <TextBlock Text="Select:" Foreground="{DynamicResource TextMuted}"
                   FontSize="12" VerticalAlignment="Center"/>
        <Button Classes="ghost" FontSize="12" Padding="8,4"
                Command="{Binding SelectAllCommand}" Content="All"/>
        <TextBlock Text="·" Foreground="{DynamicResource TextMuted}"
                   FontSize="12" VerticalAlignment="Center"/>
        <Button Classes="ghost" FontSize="12" Padding="8,4"
                Command="{Binding SelectNoneCommand}" Content="None"/>
        <TextBlock Text="·" Foreground="{DynamicResource TextMuted}"
                   FontSize="12" VerticalAlignment="Center"/>
        <Button Classes="ghost" FontSize="12" Padding="8,4"
                Command="{Binding SelectRecommendedCommand}" Content="Recommended"/>
        <TextBlock Text="(tweaks with no warnings)"
                   Foreground="{DynamicResource TextMuted}"
                   FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0"/>
      </StackPanel>

      <!-- Progress bar (visible while running) -->
      <Border Classes="card" Margin="0,10,0,0" Padding="14,10"
              IsVisible="{Binding IsBusy}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding ProgressLabel}"
                     Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
          <ProgressBar Value="{Binding ProgressDone}" Maximum="{Binding ProgressTotal}"
                       Minimum="0" IsIndeterminate="False" Height="5" CornerRadius="3"/>
        </StackPanel>
      </Border>

      <!-- Status message -->
      <Border Classes="card" Margin="0,6,0,0" Padding="14,8"
              IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
      </Border>

      <!-- Search + Category filter -->
      <Grid ColumnDefinitions="*,8,160" Margin="0,10,0,0">
        <TextBox Grid.Column="0" Watermark="Search tweaks…" Text="{Binding SearchQuery}"/>
        <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"/>
      </Grid>

    </StackPanel>

    <!-- ── Tweaks list ── -->
    <ScrollViewer Grid.Row="1" Padding="28,0,28,24">
      <ItemsControl ItemsSource="{Binding FilteredTweaks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:TweakItemViewModel}">
            <Border Classes="card" Margin="0,0,0,8" Padding="16,12">
              <Grid ColumnDefinitions="*,Auto">

                <!-- Left: all text content -->
                <StackPanel Grid.Column="0" Spacing="5" Margin="0,0,12,0">

                  <!-- Title + badges -->
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Tweak.Title}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    <Border Classes="badge" Background="{DynamicResource HoverBg}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding Tweak.Category}" FontSize="11"
                                 Foreground="{DynamicResource TextMuted}"/>
                    </Border>
                    <Border Classes="badge-warning" VerticalAlignment="Center"
                            IsVisible="{Binding Tweak.Warning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                      <TextBlock Text="⚠ Warning" FontSize="11"
                                 Foreground="{DynamicResource WarningBrush}"/>
                    </Border>
                  </StackPanel>

                  <!-- Description -->
                  <TextBlock Text="{Binding Tweak.Description}" Classes="label"
                             TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"/>

                  <!-- Warning box -->
                  <Border IsVisible="{Binding Tweak.Warning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          Background="#1a1200" CornerRadius="6" Padding="10,6" Margin="0,2,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <mi:MaterialIcon Kind="AlertOutline" Width="14" Height="14"
                                       Foreground="{DynamicResource WarningBrush}"
                                       VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Tweak.Warning}" FontSize="12"
                                 Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <!-- Result status -->
                  <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                          CornerRadius="6" Padding="10,4" Margin="0,2,0,0"
                          Background="{DynamicResource HoverBg}">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"/>
                  </Border>

                </StackPanel>

                <!-- Right: toggle only -->
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsActive}"
                              OffContent="" OnContent="" VerticalAlignment="Top"
                              Margin="0,2,0,0"/>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>
</UserControl>
